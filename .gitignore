node_modules/
.next/
out/
frontend/.next/
frontend/node_modules/

# IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Testing
.coverage
htmlcov/
.pytest_cache/

# Temp and debug files (IMP-012)
backend/temp_*.py
nohup.out
*.log
.env.local
frontend/.env.local
