# ── AaharAI NutriSync Environment Variables ──

# ── Auth / Security ──
# CRITICAL: Generate a strong SECRET_KEY with:
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_secret_key_here_change_in_production

# ── Database ──
# PostgreSQL (production):
# DATABASE_URL=postgresql://nutrisync:password@localhost:5432/nutrisync
# SQLite (development):
# Leave empty to use SQLite at backend/nutrisync.db
DATABASE_URL=

# PostgreSQL connection details (used if DATABASE_URL not set):
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=nutrisync
POSTGRES_PASSWORD=
POSTGRES_DB=nutrisync

# ── Ollama (primary LLM) ──
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:4b
OLLAMA_EMBED_MODEL=nomic-embed-text

# ── Groq (fallback LLM) ──
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama3-70b-8192

# ── Debug ──
DEBUG=false

